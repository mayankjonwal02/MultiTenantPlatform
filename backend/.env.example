# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True

# Database Configuration
DB_NAME=multitenant_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost  # Use 'postgres' when running in Docker
DB_PORT=5432

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP Email Configuration (Gmail)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000

# Celery Configuration (for localhost development)
# Use localhost when running locally, redis when running in Docker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# PostgreSQL Docker variables (used by docker-compose)
POSTGRES_DB=multitenant_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Redis Docker variables (used by docker-compose)
REDIS_PORT=6379
